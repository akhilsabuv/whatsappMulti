NODE_ENV=development

POSTGRES_DB=whatsapp_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql://postgres:replace-with-a-strong-database-password@postgres:5432/whatsapp_platform?schema=public

REDIS_URL=redis://redis:6379

JWT_SECRET=replace-with-at-least-32-random-characters
ENCRYPTION_SECRET=replace-with-exactly-32-characters

BACKEND_PORT=3001
FRONTEND_PORT=3000
WORKER_PORT=3010
BACKEND_PUBLIC_PORT=3001
FRONTEND_PUBLIC_PORT=3100
POSTGRES_PORT=5433
REDIS_PORT=6380

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3100
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100
ENABLE_SWAGGER=true

SUPERADMIN_EMAIL=owner@example.invalid
SUPERADMIN_PASSWORD=replace-with-a-strong-initial-password
DEFAULT_ADMIN_EMAIL=admin@example.invalid
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-initial-password

FILE_MAX_MB=10
UPLOAD_DIR=/shared/uploads
MOCK_WHATSAPP=false
PORTAL_TOKEN_TTL=24h

BACKUP_DIR=/shared/backups/database
BACKUP_RETAIN_COUNT=14

# Optional production hardening.
# Set CLAMSCAN_PATH=/usr/bin/clamscan and REQUIRE_MALWARE_SCAN=true after adding
# a scanner binary to the backend runtime image or host environment.
CLAMSCAN_PATH=
REQUIRE_MALWARE_SCAN=false
CLAMSCAN_TIMEOUT_MS=30000

# Optional alert sink for worker dead-letter events.
ALERT_WEBHOOK_URL=
DEAD_LETTER_RETAIN_COUNT=500
